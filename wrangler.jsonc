{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sori",
  "compatibility_date": "2026-04-23",
  "observability": {
    "enabled": true
  },
  "main": "_worker.js",
  "assets": {
    "directory": ".",
    "excludes": ["sitemap.xml"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
